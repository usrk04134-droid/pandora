        </mxCell>
        <UserObject label="&lt;div&gt;&lt;b&gt;Version Breakdown:&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;p&gt;Given a version number MAJOR.MINOR.PATCH, increment the:&lt;/p&gt;&lt;ol&gt;&lt;li&gt;&lt;font color=&quot;#c061cb&quot;&gt;MAJOR version when you make incompatible API changes&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#ffa348&quot;&gt;MINOR version when you add functionality in a backward compatible&lt;br&gt;manner&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#26a269&quot;&gt;PATCH version when you make backward compatible bug fixes&lt;/font&gt;&lt;/li&gt;&lt;/ol&gt;&lt;p&gt;Additional labels for pre-release and build metadata are available as extensions&lt;br&gt;to the MAJOR.MINOR.PATCH format.&lt;br&gt;&lt;/p&gt;&lt;/div&gt;" link="https://semver.org/" id="-6Dwyp3G_t8F9QZV2e53-43">
          <mxCell style="text;html=1;align=left;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;" parent="1" vertex="1">
